# =============================================================================
# LandChain Platform – Root Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Each sub-project also has its own .env file:
#   backend/  → backend/.env          (copy from backend/.env.example)
#   frontend/ → frontend/.env.local   (copy from frontend/.env.local.example)
# =============================================================================

# --- PostgreSQL (used by Docker Compose) -------------------------------------
POSTGRES_USER=landchain
POSTGRES_PASSWORD=landchain_secret
POSTGRES_DB=landchain

# --- Backend -----------------------------------------------------------------
PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://neondb_owner:npg_AYhHM7SyQUK5@ep-rough-moon-ad6827ca-pooler.c-2.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
JWT_SECRET=change_me_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d

# --- IPFS / Pinata -----------------------------------------------------------
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET=your_pinata_secret_api_key
PINATA_GATEWAY=https://gateway.pinata.cloud

# --- Blockchain --------------------------------------------------------------
BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545
PRIVATE_KEY=your_wallet_private_key_without_0x_prefix
PROPERTY_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
TRANSFER_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
MORTGAGE_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# --- CORS --------------------------------------------------------------------
CORS_ORIGIN=http://localhost:3001

# --- Email (optional – console logs in development) --------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_smtp_password
EMAIL_FROM=noreply@landchain.io

# --- Frontend ----------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token
